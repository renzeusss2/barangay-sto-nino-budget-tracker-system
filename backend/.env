# ================================================
# Barangay Sto. Niño Budget System - Environment
# ================================================

# --- DEVELOPMENT (SQLite - default, no setup needed) ---
# DATABASE_URL=sqlite+aiosqlite:///./barangay_budget.db

# --- PRODUCTION (PostgreSQL) ---
# Option 1: Local PostgreSQL
# DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/barangay_budget

# Option 2: Supabase (free tier)
# DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@db.xxxx.supabase.co:5432/postgres

# Option 3: Railway (auto-provided as DATABASE_URL)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname  ← auto-converted to asyncpg

# Option 4: Neon (free serverless PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?ssl=require

# JWT Secret Key
SECRET_KEY=6e1d26a943ca7088d5e0dc0f26633a5e896a3a4f2d402cb39eba25d9fa2d45a8

# Uncomment the PostgreSQL URL you want to use:
DATABASE_URL=sqlite+aiosqlite:///./barangay_budget.db
# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Required for password reset emails.
#
# IMPORTANT: Use a Gmail App Password — NOT your regular Gmail password.
# Steps to generate one:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification (required)
#   3. Search "App passwords" → create one (select "Mail")
#   4. Copy the 16-character code and paste it below (spaces are optional)
#
GMAIL_ADDRESS=renzeusalpuerto@gmail.com
GMAIL_APP_PASSWORD=ubaj ajgk uomo axty

# URL where your frontend is hosted (used to build the reset link in emails)
FRONTEND_URL=http://localhost:3000

# Optional: how long reset tokens stay valid (default: 30 minutes)
# RESET_TOKEN_EXPIRE_MINUTES=30

# Optional: secret code required to register admin/treasurer/auditor accounts
ADMIN_REGISTRATION_CODE=BRGY_STO.NIÑO@2026!